{
  "manifest_version": 3,
  "name": "Aura — AI Browser Companion",
  "version": "0.1.0",
  "description": "AI-powered new tab: mood-tuned feed, AI search, wellness nudges, and mini games.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "system.memory",
    "system.cpu",
    "idle"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://newsapi.org/*",
    "https://api.jikan.moe/*",
    "https://hacker-news.firebaseio.com/*",
    "https://dev.to/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/tracker.ts"],
      "run_at": "document_idle"
    }
  ],
  "chrome_url_overrides": {
    "newtab": "src/newtab/index.html"
  }
}
